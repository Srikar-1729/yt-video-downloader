# Configuration file for YouTube Video Downloader

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Download Settings
DOWNLOAD_FOLDER=downloads
MAX_VIDEO_SIZE_MB=5000
MAX_DURATION_SECONDS=14400  # 4 hours

# Audio Settings
AUDIO_QUALITY=192  # kbps
AUDIO_FORMAT=mp3

# Video Settings
VIDEO_FORMAT=mp4
DEFAULT_VIDEO_QUALITY=720
